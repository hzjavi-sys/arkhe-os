"use client";

import React, { useMemo, useState } from "react";
import AppShell from "../../components/arkhe/AppShell";
import { profesiones } from "../../lib/profesiones";

export default function InteligenciasPage() {
  const [q, setQ] = useState("");

  const lista = useMemo(() => {
    const qq = q.trim().toLowerCase();
    if (!qq) return profesiones;
    return profesiones.filter((p) => p.toLowerCase().includes(qq));
  }, [q]);

  return (
    <AppShell titulo="Inteligencias">
      <div style={{ display: "flex", gap: 12, alignItems: "center", flexWrap: "wrap", marginBottom: 12 }}>
        <div style={{ fontSize: 18, fontWeight: 900 }}>Profesiones ({lista.length})</div>
        <input
          value={q}
          onChange={(e) => setQ(e.target.value)}
          placeholder="Buscar profesión..."
          style={{
            flex: "1 1 320px",
            maxWidth: 520,
            padding: "12px 14px",
            borderRadius: 12,
            border: "1px solid rgba(0,0,0,0.10)",
            background: "rgba(255,255,255,0.85)",
            outline: "none",
            fontSize: 16,
          }}
        />
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(260px, 1fr))", gap: 12 }}>
        {lista.map((p, idx) => (
          <div
            key={`${p}-${idx}`}
            style={{
              borderRadius: 14,
              padding: 14,
              background: "rgba(255,255,255,0.85)",
              border: "1px solid rgba(0,0,0,0.08)",
              boxShadow: "0 10px 30px rgba(0,0,0,0.06)",
            }}
          >
            <div style={{ fontWeight: 900, fontSize: 16, lineHeight: 1.2 }}>{p}</div>
            <div style={{ marginTop: 6, fontSize: 13, opacity: 0.7 }}>
              Integración lista para conectar al “Cerebro”.
            </div>
          </div>
        ))}
      </div>
    </AppShell>
  );
}
